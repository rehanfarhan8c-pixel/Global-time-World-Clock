<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="description" content="GlobalTime Dashboard - Real-time world clocks for 40+ cities. Animated live clocks with smooth effects.">
    <title>GlobalTime | Animated World Clocks</title>
    
    <!-- Embedded SVG Logo with animation -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='46' fill='%231e293b' stroke='%2338bdf8' stroke-width='4'/%3E%3Cpath d='M50 20 L50 50 L70 65' stroke='%2338bdf8' stroke-width='5' fill='none' stroke-linecap='round'/%3E%3Ccircle cx='50' cy='50' r='4' fill='%2338bdf8'/%3E%3C/svg%3E">
    
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --accent-color: #38bdf8;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --gradient-start: #0f172a;
            --gradient-end: #1e1b4b;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Roboto', sans-serif;
        }

        body {
            background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
            color: var(--text-main);
            line-height: 1.5;
            min-height: 100vh;
            animation: bgShift 12s infinite alternate;
        }

        /* Animated gradient background */
        @keyframes bgShift {
            0% {
                background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            }
            50% {
                background: linear-gradient(135deg, #111827 0%, #2d2a5e 100%);
            }
            100% {
                background: linear-gradient(135deg, #0a0f1f 0%, #1a1a4f 100%);
            }
        }

        header {
            text-align: center;
            padding: 2rem 1.5rem;
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid rgba(56, 189, 248, 0.3);
            animation: slideDown 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-60px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1.25rem;
            flex-wrap: wrap;
        }

        .logo-svg {
            filter: drop-shadow(0 4px 12px rgba(56, 189, 248, 0.4));
            transition: transform 0.3s ease, filter 0.3s;
            animation: pulseGlow 2s infinite alternate;
        }

        @keyframes pulseGlow {
            0% {
                filter: drop-shadow(0 4px 8px rgba(56, 189, 248, 0.3));
                transform: scale(1);
            }
            100% {
                filter: drop-shadow(0 8px 20px rgba(56, 189, 248, 0.7));
                transform: scale(1.02);
            }
        }

        .logo-svg:hover {
            transform: rotate(8deg) scale(1.05);
            filter: drop-shadow(0 0 12px #38bdf8);
        }

        .header-text h1 {
            font-size: 2.2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ffffff 0%, #38bdf8 80%);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            animation: fadeInUp 0.6s ease;
        }

        .header-text p {
            color: var(--text-muted);
            animation: fadeInUp 0.6s ease 0.1s both;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* Search Bar with animation */
        .search-container {
            margin-bottom: 2rem;
            display: flex;
            justify-content: center;
        }

        .search-bar {
            width: 100%;
            max-width: 600px;
            padding: 0.9rem 1.8rem;
            border-radius: 60px;
            border: 2px solid #334155;
            background-color: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(4px);
            color: var(--text-main);
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
            animation: fadeInScale 0.5s ease;
        }

        @keyframes fadeInScale {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .search-bar:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.3), 0 0 15px rgba(56, 189, 248, 0.5);
            transform: scale(1.01);
        }

        /* Animated stats */
        .stats {
            text-align: center;
            font-size: 0.85rem;
            color: #a5b4fc;
            margin-bottom: 1.5rem;
            animation: fadeIn 0.8s;
        }

        /* Clock Grid */
        .clock-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.8rem;
        }

        /* Card entrance animation with staggered effect */
        .clock-card {
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.9), rgba(24, 34, 55, 0.95));
            backdrop-filter: blur(4px);
            padding: 1.6rem;
            border-radius: 32px;
            text-align: center;
            box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(56, 189, 248, 0.2);
            transition: all 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            animation: cardReveal 0.5s ease backwards;
            position: relative;
            overflow: hidden;
        }

        /* Staggered animation delay */
        .clock-card:nth-child(1) { animation-delay: 0.02s; }
        .clock-card:nth-child(2) { animation-delay: 0.05s; }
        .clock-card:nth-child(3) { animation-delay: 0.08s; }
        .clock-card:nth-child(4) { animation-delay: 0.11s; }
        .clock-card:nth-child(5) { animation-delay: 0.14s; }
        .clock-card:nth-child(6) { animation-delay: 0.17s; }
        .clock-card:nth-child(7) { animation-delay: 0.20s; }
        .clock-card:nth-child(8) { animation-delay: 0.23s; }
        .clock-card:nth-child(9) { animation-delay: 0.26s; }
        .clock-card:nth-child(10) { animation-delay: 0.29s; }
        .clock-card:nth-child(11) { animation-delay: 0.32s; }
        .clock-card:nth-child(12) { animation-delay: 0.35s; }
        .clock-card:nth-child(13) { animation-delay: 0.38s; }
        .clock-card:nth-child(14) { animation-delay: 0.41s; }
        .clock-card:nth-child(15) { animation-delay: 0.44s; }
        .clock-card:nth-child(16) { animation-delay: 0.47s; }
        .clock-card:nth-child(17) { animation-delay: 0.50s; }
        .clock-card:nth-child(18) { animation-delay: 0.53s; }
        .clock-card:nth-child(19) { animation-delay: 0.56s; }
        .clock-card:nth-child(20) { animation-delay: 0.59s; }

        @keyframes cardReveal {
            from {
                opacity: 0;
                transform: translateY(40px) scale(0.96);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* Hover effect with glow and lift */
        .clock-card:hover {
            transform: translateY(-10px) scale(1.02);
            border-color: #38bdf8;
            box-shadow: 0 20px 35px -12px rgba(56, 189, 248, 0.4);
            background: linear-gradient(145deg, #243049, #1a2538);
        }

        /* Animated shine overlay on hover */
        .clock-card::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(56,189,248,0.15) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.5s;
            pointer-events: none;
            border-radius: 32px;
        }

        .clock-card:hover::after {
            opacity: 1;
        }

        .clock-card h3 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .country-badge {
            font-size: 0.7rem;
            background: #0f172a;
            padding: 0.2rem 0.7rem;
            border-radius: 20px;
            color: #a5b4fc;
            font-weight: normal;
            transition: all 0.2s;
        }

        .clock-card:hover .country-badge {
            background: #1e293b;
            color: #38bdf8;
        }

        .timezone-offset {
            font-size: 0.7rem;
            color: var(--text-muted);
            background: rgba(15, 23, 42, 0.7);
            display: inline-block;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            margin-bottom: 1rem;
        }

        /* Animated time display - subtle pulse on each update */
        .time-display {
            font-size: 2.3rem;
            font-weight: 700;
            color: var(--accent-color);
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
            transition: text-shadow 0.1s ease;
            animation: timePulse 0.3s ease-out;
        }

        @keyframes timePulse {
            0% {
                text-shadow: 0 0 0px #38bdf8;
                transform: scale(1);
            }
            50% {
                text-shadow: 0 0 8px #38bdf8, 0 0 12px #38bdf8;
                transform: scale(1.02);
            }
            100% {
                text-shadow: 0 0 0px #38bdf8;
                transform: scale(1);
            }
        }

        .date-display {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-weight: 500;
            transition: all 0.2s;
        }

        /* No results message animation */
        .no-results {
            text-align: center;
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(8px);
            padding: 2.5rem;
            border-radius: 2rem;
            grid-column: 1 / -1;
            font-size: 1.1rem;
            color: #cbd5e1;
            border: 1px dashed #38bdf8;
            animation: fadeInUp 0.4s ease;
        }

        footer {
            text-align: center;
            margin-top: 3rem;
            padding: 1.5rem;
            font-size: 0.8rem;
            color: #7e8aa8;
            border-top: 1px solid rgba(56, 189, 248, 0.2);
            animation: fadeIn 1s;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Responsive */
        @media (max-width: 640px) {
            .clock-grid {
                gap: 1rem;
            }
            .time-display {
                font-size: 1.8rem;
            }
            .header-text h1 {
                font-size: 1.7rem;
            }
            .clock-card {
                padding: 1.2rem;
            }
        }
    </style>
</head>
<body>

<header>
    <div class="logo-wrapper">
        <div class="logo-svg">
            <svg width="56" height="56" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="46" fill="#1e293b" stroke="#38bdf8" stroke-width="3.5"/>
                <path d="M50 25 L50 50 L68 62" stroke="#38bdf8" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="50" cy="50" r="5" fill="#38bdf8" stroke="#0f172a" stroke-width="1.5"/>
                <path d="M28 33 L36 40 M72 33 L64 40" stroke="#7aa9d4" stroke-width="3" stroke-linecap="round" opacity="0.8"/>
                <circle cx="50" cy="50" r="32" stroke="#2d4a6e" stroke-width="1.8" stroke-dasharray="4 4" fill="none"/>
            </svg>
        </div>
        <div class="header-text">
            <h1>GlobalTime Dashboard</h1>
            <p>🌎 40+ animated world clocks • Real-time • Search by city or country</p>
        </div>
    </div>
</header>

<div class="container">
    <div class="search-container">
        <input type="text" id="searchBar" class="search-bar" placeholder="🔍 Search for any city or country... (e.g., Tokyo, Brazil, France, Sydney)" aria-label="Filter cities">
    </div>
    <div class="stats" id="stats">✨ Loading animated clocks...</div>
    <div class="clock-grid" id="clockGrid"></div>
</div>

<footer>
    <p>⏱️ Live synchronized times • Smooth second updates • Hover for glow & lift</p>
</footer>

<script>
    // Extensive cities list with countries and timezones
    const citiesData = [
        { name: "🇺🇸 New York", country: "USA", zone: "America/New_York", tags: "usa united states america nyc est" },
        { name: "🇺🇸 Los Angeles", country: "USA", zone: "America/Los_Angeles", tags: "la california pst" },
        { name: "🇺🇸 Chicago", country: "USA", zone: "America/Chicago", tags: "illinois midwest cst" },
        { name: "🇨🇦 Toronto", country: "Canada", zone: "America/Toronto", tags: "ontario canada est" },
        { name: "🇨🇦 Vancouver", country: "Canada", zone: "America/Vancouver", tags: "bc british columbia pst" },
        { name: "🇲🇽 Mexico City", country: "Mexico", zone: "America/Mexico_City", tags: "cdmx" },
        { name: "🇧🇷 São Paulo", country: "Brazil", zone: "America/Sao_Paulo", tags: "brasil brazil south america" },
        { name: "🇬🇧 London", country: "United Kingdom", zone: "Europe/London", tags: "england gmt uk great britain" },
        { name: "🇫🇷 Paris", country: "France", zone: "Europe/Paris", tags: "france europe cet" },
        { name: "🇩🇪 Berlin", country: "Germany", zone: "Europe/Berlin", tags: "germany de" },
        { name: "🇮🇹 Rome", country: "Italy", zone: "Europe/Rome", tags: "italy" },
        { name: "🇪🇸 Madrid", country: "Spain", zone: "Europe/Madrid", tags: "spain" },
        { name: "🇳🇱 Amsterdam", country: "Netherlands", zone: "Europe/Amsterdam", tags: "holland" },
        { name: "🇷🇺 Moscow", country: "Russia", zone: "Europe/Moscow", tags: "russia msk" },
        { name: "🇹🇷 Istanbul", country: "Turkey", zone: "Europe/Istanbul", tags: "turkey" },
        { name: "🇮🇳 New Delhi", country: "India", zone: "Asia/Kolkata", tags: "india ist mumbai" },
        { name: "🇮🇳 Mumbai", country: "India", zone: "Asia/Kolkata", tags: "bombay maharashtra" },
        { name: "🇯🇵 Tokyo", country: "Japan", zone: "Asia/Tokyo", tags: "japan jst" },
        { name: "🇨🇳 Shanghai", country: "China", zone: "Asia/Shanghai", tags: "china cst beijing" },
        { name: "🇭🇰 Hong Kong", country: "Hong Kong", zone: "Asia/Hong_Kong", tags: "china hkt" },
        { name: "🇰🇷 Seoul", country: "South Korea", zone: "Asia/Seoul", tags: "korea kst" },
        { name: "🇸🇬 Singapore", country: "Singapore", zone: "Asia/Singapore", tags: "sg" },
        { name: "🇦🇺 Sydney", country: "Australia", zone: "Australia/Sydney", tags: "australia nsw aedt" },
        { name: "🇦🇺 Perth", country: "Australia", zone: "Australia/Perth", tags: "western australia" },
        { name: "🇳🇿 Auckland", country: "New Zealand", zone: "Pacific/Auckland", tags: "nz nzt" },
        { name: "🇿🇦 Johannesburg", country: "South Africa", zone: "Africa/Johannesburg", tags: "south africa sa" },
        { name: "🇪🇬 Cairo", country: "Egypt", zone: "Africa/Cairo", tags: "egypt" },
        { name: "🇦🇪 Dubai", country: "UAE", zone: "Asia/Dubai", tags: "united arab emirates gst" },
        { name: "🇮🇱 Jerusalem", country: "Israel", zone: "Asia/Jerusalem", tags: "israel" },
        { name: "🇸🇦 Riyadh", country: "Saudi Arabia", zone: "Asia/Riyadh", tags: "saudi" },
        { name: "🇵🇰 Karachi", country: "Pakistan", zone: "Asia/Karachi", tags: "pakistan" },
        { name: "🇧🇩 Dhaka", country: "Bangladesh", zone: "Asia/Dhaka", tags: "bangladesh" },
        { name: "🇮🇩 Jakarta", country: "Indonesia", zone: "Asia/Jakarta", tags: "indonesia" },
        { name: "🇵🇭 Manila", country: "Philippines", zone: "Asia/Manila", tags: "philippines" },
        { name: "🇻🇳 Ho Chi Minh", country: "Vietnam", zone: "Asia/Ho_Chi_Minh", tags: "vietnam" },
        { name: "🇦🇷 Buenos Aires", country: "Argentina", zone: "America/Argentina/Buenos_Aires", tags: "argentina" },
        { name: "🇨🇱 Santiago", country: "Chile", zone: "America/Santiago", tags: "chile" },
        { name: "🇨🇴 Bogotá", country: "Colombia", zone: "America/Bogota", tags: "colombia" },
        { name: "🇵🇪 Lima", country: "Peru", zone: "America/Lima", tags: "peru" },
        { name: "🇨🇭 Zurich", country: "Switzerland", zone: "Europe/Zurich", tags: "swiss" }
    ];

    const clockGrid = document.getElementById('clockGrid');
    const searchInput = document.getElementById('searchBar');
    const statsSpan = document.getElementById('stats');

    let clockElements = [];

    function buildClockGrid() {
        clockGrid.innerHTML = '';
        clockElements = [];
        
        citiesData.forEach((city, idx) => {
            const timeId = `time_${idx}`;
            const dateId = `date_${idx}`;
            const card = document.createElement('div');
            card.className = 'clock-card';
            card.setAttribute('data-name', `${city.name} ${city.country} ${city.tags}`.toLowerCase());
            
            card.innerHTML = `
                <h3>${city.name} <span class="country-badge">${city.country}</span></h3>
                <div class="timezone-offset">${city.zone}</div>
                <div class="time-display" id="${timeId}">--:--:--</div>
                <div class="date-display" id="${dateId}">Loading...</div>
            `;
            clockGrid.appendChild(card);
            clockElements.push({
                zone: city.zone,
                timeElem: document.getElementById(timeId),
                dateElem: document.getElementById(dateId),
                card: card
            });
        });
        updateStats();
    }

    // Function to update clocks with animation class on time elements
    let lastSecond = -1;
    function updateAllClocks() {
        const now = new Date();
        const currentSecond = now.getSeconds();
        const shouldAnimate = currentSecond !== lastSecond;
        
        for (let item of clockElements) {
            try {
                const timeString = now.toLocaleTimeString('en-US', {
                    timeZone: item.zone,
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: true
                });
                const dateString = now.toLocaleDateString('en-US', {
                    timeZone: item.zone,
                    weekday: 'short',
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                });
                if (item.timeElem) {
                    if (shouldAnimate) {
                        item.timeElem.style.animation = 'none';
                        item.timeElem.offsetHeight; // force reflow
                        item.timeElem.style.animation = 'timePulse 0.25s ease-out';
                    }
                    item.timeElem.textContent = timeString;
                }
                if (item.dateElem) item.dateElem.textContent = dateString;
            } catch (e) {
                if (item.timeElem) item.timeElem.textContent = now.toLocaleTimeString();
                if (item.dateElem) item.dateElem.textContent = now.toLocaleDateString();
            }
        }
        lastSecond = currentSecond;
    }

    function updateStats() {
        const visible = Array.from(document.querySelectorAll('.clock-card')).filter(card => card.style.display !== 'none').length;
        statsSpan.textContent = `🌍 Showing ${visible} of ${citiesData.length} world cities · Type to filter · ✨ Hover for effects`;
    }

    function filterClocks() {
        const query = searchInput.value.trim().toLowerCase();
        const cards = document.querySelectorAll('.clock-card');
        let visibleCount = 0;
        
        cards.forEach(card => {
            const searchData = card.getAttribute('data-name') || '';
            const matches = query === '' || searchData.includes(query);
            card.style.display = matches ? '' : 'none';
            if (matches) visibleCount++;
        });
        
        let existingMsg = document.getElementById('noResultsMsg');
        if (visibleCount === 0 && cards.length > 0) {
            if (!existingMsg) {
                const noMsg = document.createElement('div');
                noMsg.id = 'noResultsMsg';
                noMsg.className = 'no-results';
                noMsg.innerHTML = '🔍 No cities match your search. Try "France", "Tokyo", "Brazil", or "Sydney".';
                clockGrid.appendChild(noMsg);
            }
        } else if (existingMsg) existingMsg.remove();
        
        updateStats();
    }

    let debounceTimer;
    function debouncedFilter() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(filterClocks, 200);
    }

    function init() {
        buildClockGrid();
        updateAllClocks();
        setInterval(updateAllClocks, 1000);
        searchInput.addEventListener('input', debouncedFilter);
        window.addEventListener('load', () => {
            filterClocks();
            updateAllClocks();
        });
        document.addEventListener('visibilitychange', () => {
            if (!document.hidden) updateAllClocks();
        });
    }
    
    init();
</script>
</body>
</html>
